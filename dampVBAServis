0310 | ' ================================================================
0311 | ' СДВИГ ЧЕКБОКСОВ ПРИ ВСТАВКЕ СТРОКИ (вверх > вниз)
0312 | ' Вызывается из CreateRemReport ПЕРЕД вставкой строки.
0313 | ' Порядок обхода — от бОльших строк к меньшим (сортировка DESC),
0314 | ' чтобы не было конфликта имён при переименовании вверх.
0315 | ' ================================================================
0316 | Private Sub RealignCheckboxes(ByVal wsRep As Worksheet, ByVal fromRow As Long)
0317 |     Dim cb       As CheckBox
0318 |     Dim cbRows() As Long
0319 |     Dim n        As Long
0320 | 
0321 |     For Each cb In wsRep.CheckBoxes
0322 |         If Left(cb.Name, 7) = "cbWarr_" Then
0323 |             Dim r As Long
0324 |             r = CLng(Mid(cb.Name, 8))
0325 |             If r >= fromRow Then
0326 |                 ReDim Preserve cbRows(n)
0327 |                 cbRows(n) = r
0328 |                 n = n + 1
0329 |             End If
0330 |         End If
0331 |     Next cb
0332 | 
0333 |     If n = 0 Then Exit Sub
0334 | 
0335 |     ' Сортировка по УБЫВАНИЮ — переименовываем сначала самые нижние
0336 |     Dim i As Long, j As Long, tmp As Long
0337 |     For i = 0 To n - 2
0338 |         For j = 0 To n - i - 2
0339 |             If cbRows(j) < cbRows(j + 1) Then
0340 |                 tmp = cbRows(j): cbRows(j) = cbRows(j + 1): cbRows(j + 1) = tmp
0341 |             End If
0342 |         Next j
0343 |     Next i
0344 | 
0345 |     For i = 0 To n - 1
0346 |         On Error Resume Next
0347 |         wsRep.CheckBoxes("cbWarr_" & cbRows(i)).Name = "cbWarr_" & (cbRows(i) + 1)
0348 |         On Error GoTo 0
0349 |     Next i
0350 | End Sub
