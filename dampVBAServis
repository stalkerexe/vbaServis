0147 | 
0148 | 
0149 | ' ================================================================
0150 | ' ЗАГРУЗКА ЗАКАЗА ИЗ ТАБЛИЦЫ В ОБЪЕКТ
0151 | ' ================================================================
0152 | Private Function LoadOrderFromTable( _
0153 |     ByVal lo As ListObject, _
0154 |     ByVal rowIndex As Long _
0155 | ) As clsOrder
0156 | 
0157 |     Dim o As New clsOrder
0158 |     Dim r As Range
0159 | 
0160 |     Set r = lo.DataBodyRange.Rows(rowIndex)
0161 | 
0162 |     With o
0163 |         .dateIn = r.Cells(1, TableCol(lo, COL_DATE)).Value
0164 |         .Organization = r.Cells(1, TableCol(lo, COL_PRIM)).Value
0165 |         .phone = r.Cells(1, TableCol(lo, COL_REM)).Value
0166 |         .contactName = r.Cells(1, TableCol(lo, COL_CNAME)).Value
0167 |         .device = r.Cells(1, TableCol(lo, COL_NAME)).Value
0168 |         .SerialNumber = r.Cells(1, TableCol(lo, COL_DESC)).Value
0169 |         .Complect = r.Cells(1, TableCol(lo, COL_NOTE)).Value
0170 |         .Category = r.Cells(1, TableCol(lo, COL_CATEGORY)).Value
0171 |         .Defect = r.Cells(1, TableCol(lo, COL_OTHER)).Value
0172 |         .ControlDate = r.Cells(1, TableCol(lo, COL_DGV)).Value
