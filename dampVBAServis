0061 |         Set rngNDATF = loF.ListColumns(COL_NDAT - loF.Range.Column + 1).DataBodyRange
0062 | 
0063 |         cWorkF = Application.CountIf(rngStatusF, STATUS_WORK)
0064 |         cDoneF = Application.CountIf(rngStatusF, STATUS_DONE)
0065 |         cDebtF = Application.CountIf(rngStatusF, STATUS_DEBT)
0066 |         cOverF = CountOverdueOrders(DATA_SHEET)
0067 | 
0068 |         cForgotDoneF = Application.CountIfs( _
0069 |                            rngStatusF, STATUS_DONE, _
0070 |                            rngNDATF, "<" & forgotThreshold)
0071 |         cForgotDebtF = Application.CountIfs( _
0072 |                            rngStatusF, STATUS_DEBT, _
0073 |                            rngNDATF, "<" & forgotThreshold)
