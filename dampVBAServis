=== COMPONENT: modSearchHelper ===
TYPE: Standard Module
--------------------------------------------------
0001 | Option Explicit
0002 | '=================================================
0003 | ' МОДУЛЬ: modSearchHelper
0004 | '
0005 | ' Назначение:
0006 | '   Формирование и обновление поискового ключа
0007 | '   (__SearchKey) для таблиц Таблица2 / Таблица3
0008 | '=================================================
0009 | 
0010 | Public Const SEARCH_KEY_COL As String = "__SearchKey"
0011 | 
0012 | '=================================================
0013 | ' СБОР ПОИСКОВОГО КЛЮЧА ОДНОЙ СТРОКИ
0014 | '=================================================
0015 | ' ИСПРАВЛЕНИЕ: заменено .Text на .Value + явное CStr()
0016 | '
0017 | ' Причина: .Text зависит от ширины столбца в Excel.
0018 | ' Если столбец слишком узкий — .Text возвращает "###"
0019 | ' вместо реального значения. Это ломает поиск:
0020 | ' пользователь вводит номер или название, а в ключе
0021 | ' стоит "###" и совпадения не находится.
0022 | '
0023 | ' .Value всегда возвращает реальное содержимое ячейки
0024 | ' независимо от форматирования и ширины столбца.
0025 | ' CStr() безопасно преобразует даты и числа в строку,
0026 | ' а для пустых ячеек (Empty) вернёт "" без ошибки.
0027 | '=================================================
0028 | Public Function BuildSearchKey(ByVal lo As ListObject, ByVal rowIndex As Long) As String
0029 | 
0030 |     Dim c       As ListColumn
0031 |     Dim result  As String
0032 |     Dim rawVal  As Variant
0033 |     Dim strVal  As String
0034 | 
0035 |     For Each c In lo.ListColumns
0036 | 
0037 |         If c.Name <> SEARCH_KEY_COL Then
0038 | 
0039 |             rawVal = c.DataBodyRange.Cells(rowIndex).Value
0040 | 
0041 |             ' Даты Excel хранит как числа (Double).
0042 |             ' Если не обработать отдельно — CStr вернёт числовое
0043 |             ' представление ("46000"), а не "01.01.2026".
0044 |             ' Пользователь ищет по дате в читаемом формате,
0045 |             ' поэтому конвертируем через Format.
0046 |             If IsDate(rawVal) And Not IsEmpty(rawVal) Then
0047 |                 strVal = Format(CDate(rawVal), "dd.mm.yyyy")
0048 |             Else
0049 |                 strVal = CStr(rawVal & "")  ' "" защищает от Empty/Null
0050 |             End If
0051 | 
0052 |             result = result & " " & LCase(strVal)
0053 | 
0054 |         End If
0055 | 
0056 |     Next c
0057 | 
0058 |     BuildSearchKey = Trim(result)
0059 | 
0060 | End Function
0061 | 
0062 | 
0063 | '=================================================
0064 | ' ОБНОВЛЕНИЕ КЛЮЧА ДЛЯ ОДНОЙ СТРОКИ
0065 | ' (без изменений — логика верная)
0066 | '=================================================
0067 | Public Sub UpdateSearchKeyForRow(ByVal lo As ListObject, ByVal rowIndex As Long)
0068 | 
0069 |     If rowIndex < 1 Or rowIndex > lo.ListRows.Count Then Exit Sub
0070 | 
0071 |     lo.ListColumns(SEARCH_KEY_COL).DataBodyRange.Cells(rowIndex).Value = _
0072 |         BuildSearchKey(lo, rowIndex)
0073 | 
0074 | End Sub
0075 | 
0076 | 
0077 | ' ================================================================
0078 | ' ПЕРЕСБОРКА КЛЮЧЕЙ ДЛЯ КОНКРЕТНОГО ЛИСТА
0079 | ' ================================================================
0080 | ' УЛУЧШЕНИЕ: добавлено Application.EnableEvents = False
0081 | ' чтобы массовая перезапись __SearchKey не триггерила
0082 | ' Worksheet_Change на каждую строку (что вызывало бы
0083 | ' повторный UpdateSearchKeyForRow рекурсивно).
0084 | ' ================================================================
0085 | Public Sub RebuildSearchKeys_Sheet( _
0086 |     Optional sheetName As String = DATA_SHEET _
0087 | )
0088 |     Dim ws As Worksheet
0089 |     Dim lo As ListObject
0090 |     Dim i  As Long
0091 | 
0092 |     Set ws = ThisWorkbook.Sheets(sheetName)
0093 |     Set lo = ws.ListObjects(GetTableName(sheetName))
0094 | 
0095 |     If lo.DataBodyRange Is Nothing Then Exit Sub
0096 | 
0097 |     Application.ScreenUpdating = False
0098 |     Application.EnableEvents = False       ' < добавлено
0099 | 
0100 |     For i = 1 To lo.ListRows.Count
0101 |         UpdateSearchKeyForRow lo, i
0102 |     Next i
0103 | 
0104 |     Application.EnableEvents = True        ' < добавлено
0105 |     Application.ScreenUpdating = True
0106 | 
0107 | End Sub
0108 | 


