0065 |     Application.ScreenUpdating = False
0066 | 
0067 |     tblColDGV = COL_DGV - lo.Range.Column + 1
0068 |     tblColStatus = COL_STATUS - lo.Range.Column + 1
0069 | 
0070 |     colOverdue = GetOrCreateOverdueColumn(lo)
