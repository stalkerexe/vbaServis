0001 | ' ================================================================
0002 | ' МОДУЛЬ: modDeleteLine
0003 | ' Удаление выбранной строки из таблицы (Гарантийный / Платный)
0004 | ' ================================================================
0005 | ' ИСПРАВЛЕНИЯ:
0006 | '   1. Ошибка 1004 при активном фильтре — снимаем/восстанавливаем фильтр
0007 | '   2. Перед удалением записываем в Историю: было=последний статус, стало="Удалено"
0008 | ' ================================================================
0009 | Option Explicit
0010 | 
0011 | Public Sub DeleteSelectedLine( _
0012 |     Optional sheetName As String = DATA_SHEET _
0013 | )
0014 |     On Error GoTo Cleanup
0015 | 
0016 |     Dim ws           As Worksheet
0017 |     Dim lo           As ListObject
0018 |     Dim targetRow    As Long
0019 |     Dim srcIndex     As Long
0020 |     Dim orgName      As String
0021 |     Dim devName      As String
0022 |     Dim lastStatus   As String
0023 |     Dim confirm      As VbMsgBoxResult
0024 |     Dim wasFiltered  As Boolean
0025 |     Dim savedFilters As Variant
0026 | 
0027 |     Set ws = ThisWorkbook.Sheets(sheetName)
0028 |     Set lo = ws.ListObjects(GetTableName(sheetName))
0029 | 
0030 |     ' Получаем и валидируем строку
0031 |     targetRow = GetValidatedRow(ws, lo, True, sheetName)
0032 |     If targetRow = 0 Then
0033 |         ClearSelectedRow sheetName
0034 |         Exit Sub
0035 |     End If
0036 | 
0037 |     ' Читаем данные для подтверждения и истории
0038 |     orgName = Trim(ws.Cells(targetRow, COL_PRIM).Value)
0039 |     devName = Trim(ws.Cells(targetRow, COL_NAME).Value)
0040 |     lastStatus = Trim(ws.Cells(targetRow, COL_STATUS).Value)
0041 | 
0042 |     ' Двойное подтверждение
0043 |     confirm = MsgBox( _
0044 |         "Удалить заказ безвозвратно?" & vbCrLf & vbCrLf & _
0045 |         "  Организация: " & orgName & vbCrLf & _
0046 |         "  Устройство:  " & devName & vbCrLf & vbCrLf & _
0047 |         "Это действие нельзя отменить!", _
0048 |         vbYesNo + vbExclamation + vbDefaultButton2, _
0049 |         "Подтверждение удаления" _
0050 |     )
0051 |     If confirm <> vbYes Then Exit Sub
0052 | 
0053 |     Application.ScreenUpdating = False
0054 |     Application.EnableEvents = False
0055 | 
0056 |     srcIndex = targetRow - lo.DataBodyRange.Row + 1
0057 | 
0058 | 
0059 |     ' --- Расширенный журнал ---
0060 |     Dim delOrderNum As String
0061 |     Dim delCol      As Long
0062 |     delCol = GetOrderNumColumnIndex(lo)
0063 |     If delCol > 0 Then
0064 |         delOrderNum = ws.Cells(targetRow, lo.Range.Column + delCol - 1).Value
0065 |     End If
0066 |     WriteActionHistory ws, targetRow, ACTION_DELETE, delOrderNum, lastStatus, "Заказ Удален", ""
0067 | 
0068 |     ' Очищаем значок предупреждения (если был)
0069 |     ClearWarningIcon ws, targetRow
0070 | 
0071 |     ' =================================================================
0072 |     ' ИСПРАВЛЕНИЕ ОШИБКИ 1004:
0073 |     ' Excel запрещает удаление строки в таблице с активным фильтром.
0074 |     ' Сохраняем состояние всех фильтров, снимаем их, удаляем строку,
0075 |     ' затем восстанавливаем фильтры обратно.
0076 |     ' =================================================================
0077 |     wasFiltered = False
0078 | 
0079 |     If Not lo.AutoFilter Is Nothing Then
0080 |         If lo.AutoFilter.FilterMode Then
0081 |             wasFiltered = True
0082 |             savedFilters = SaveFilterState(lo)
0083 |             lo.AutoFilter.ShowAllData
0084 |         End If
0085 |     End If
0086 | 
0087 |     ' Удаляем строку из таблицы
0088 |     lo.ListRows(srcIndex).Delete
0089 | 
0090 |     ' Восстанавливаем фильтр если был активен
0091 |     If wasFiltered Then
0092 |         RestoreFilterState lo, savedFilters
0093 |     End If
0094 |     ' =================================================================
0095 | 
0096 |     ' Сбрасываем запомненную строку
0097 |     ClearSelectedRow sheetName
0098 | 
0099 |     Application.EnableEvents = True
0100 |     Application.ScreenUpdating = True
0101 | 
0102 |     ' Обновляем просрочку, счётчики, кнопки
0103 |     SyncAllAfterSave sheetName
0104 |     RebuildSearchKeys_Sheet sheetName
0105 | 
0106 |     MsgBox "Заказ удален!", vbInformation, "Удаление"
0107 | 
0108 |     Exit Sub
0109 | 
0110 | Cleanup:
0111 |     Application.EnableEvents = True
0112 |     Application.ScreenUpdating = True
0113 |     If Err.Number <> 0 Then MsgBox "Ошибка при удалении: " & Err.Description, vbCritical
0114 | End Sub
