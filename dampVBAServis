0218 | Private Function EncodeCharUTF8(ByVal ch As String) As String
0219 |     Dim bytes() As Byte, i As Integer, result As String
0220 |     Dim stream As Object
0221 |     Set stream = CreateObject("ADODB.Stream")
0222 |     stream.Type = 2
0223 |     stream.Charset = "UTF-8"
0224 |     stream.Open
0225 |     stream.WriteText ch
0226 |     stream.Position = 0
0227 |     stream.Type = 1
0228 |     stream.Position = 3
0229 |     bytes = stream.Read
0230 |     stream.Close
0231 |     Set stream = Nothing
0232 |     result = ""
0233 |     For i = 0 To UBound(bytes)
0234 |         result = result & "%" & UCase(Right("0" & Hex(bytes(i)), 2))
0235 |     Next i
0236 |     EncodeCharUTF8 = result
0237 | End Function
