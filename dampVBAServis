0013 | ' ================================================================
0014 | ' ПОЛУЧИТЬ КАРТУ ШАБЛОНА ИЗ ЛИСТА "КартаШаблонов"
0015 | ' ================================================================
0016 | Public Function GetTemplateMap(ByVal templateName As String) As Collection
0017 | 
0018 |     Dim ws     As Worksheet
0019 |     Dim lo     As ListObject
0020 |     Dim r      As ListRow
0021 |     Dim result As New Collection
0022 |     Dim item   As Object
0023 | 
0024 |     Set ws = ThisWorkbook.Sheets(MAP_SHEET)
0025 |     Set lo = ws.ListObjects(MAP_TABLE)
0026 | 
0027 |     For Each r In lo.ListRows
0028 |         If Trim(r.Range.Cells(1, lo.ListColumns("Template").Index).Value) = templateName Then
0029 | 
0030 |             Set item = CreateObject("Scripting.Dictionary")
0031 |             item("TargetCell") = r.Range.Cells(1, lo.ListColumns("TargetCell").Index).Value
0032 |             item("Expression") = r.Range.Cells(1, lo.ListColumns("Expression").Index).Value
0033 | 
0034 |             result.Add item
0035 |         End If
0036 |     Next r
0037 | 
0038 |     If result.Count = 0 Then
0039 |         MsgBox "Для шаблона """ & templateName & """ карта не найдена", vbCritical
0040 |     End If
0041 | 
0042 |     Set GetTemplateMap = result
0043 | End Function
0044 | 
0045 | 
0046 | ' ================================================================
0047 | ' ВЫЧИСЛЕНИЕ ВЫРАЖЕНИЯ ИЗ КАРТЫ ШАБЛОНА
0048 | ' ================================================================
0049 | Public Function EvaluateExpression( _
0050 |     ByVal expr As String, _
0051 |     ByVal lo As ListObject, _
0052 |     ByVal targetRow As Long _
0053 | ) As String
0054 | 
0055 |     Dim parts()  As String
0056 |     Dim part     As Variant
0057 |     Dim result   As String
0058 |     Dim colIndex As Long
0059 | 
0060 |     parts = Split(expr, "&")
0061 | 
0062 |     For Each part In parts
0063 |         part = Trim(part)
0064 | 
0065 |         ' --- строковый литерал ---
0066 |         If Left(part, 1) = """" And Right(part, 1) = """" Then
0067 |             result = result & Mid(part, 2, Len(part) - 2)
0068 | 
0069 |         ' --- поле таблицы ---
0070 |         Else
0071 |             On Error Resume Next
0072 |             colIndex = lo.ListColumns(part).Range.Column
0073 |             On Error GoTo 0
0074 | 
0075 |             If colIndex > 0 Then
0076 |                 result = result & Trim(lo.Parent.Cells(targetRow, colIndex).Value)
0077 |             End If
0078 |         End If
0079 |     Next part
0080 | 
0081 |     EvaluateExpression = Trim(result)
0082 | End Function
0083 | 
0084 | 
0085 | ' ================================================================
0086 | ' УНИВЕРСАЛЬНЫЙ ПЕРЕНОС В ШАБЛОН
0087 | ' Теперь принимает sheetName — знает откуда брать данные
0088 | ' ================================================================
0089 | Public Sub TransferRowToTemplate( _
0090 |     ByVal templateSheetName As String, _
0091 |     Optional ByVal sheetName As String = DATA_SHEET _
0092 | )
0093 | 
0094 |     Dim wsData    As Worksheet
0095 |     Dim wsTpl     As Worksheet
0096 |     Dim lo        As ListObject
0097 |     Dim targetRow As Long
0098 |     Dim mapItems  As Collection
0099 |     Dim item      As Object
0100 |     Dim valueToWrite As String
0101 | 
0102 |     Set wsData = ThisWorkbook.Sheets(sheetName)
0103 |     Set wsTpl = ThisWorkbook.Sheets(templateSheetName)
0104 |     Set lo = wsData.ListObjects(GetTableName(sheetName))
0105 | 
0106 |     ' --- получаем выбранную строку ---
0107 |     targetRow = GetSelectedRow(sheetName)
0108 | 
0109 |     If targetRow = 0 Then
0110 |         MsgBox "Не выбрана строка таблицы", vbExclamation
0111 |         Exit Sub
0112 |     End If
0113 | 
0114 |     If Intersect(wsData.Rows(targetRow), lo.DataBodyRange) Is Nothing Then
0115 |         MsgBox "Выбранная строка не относится к таблице", vbCritical
0116 |         Exit Sub
0117 |     End If
0118 | 
0119 |     ' --- карта шаблона ---
0120 |     Set mapItems = GetTemplateMap(templateSheetName)
0121 |     If mapItems.Count = 0 Then Exit Sub
0122 | 
0123 |     Application.ScreenUpdating = False
0124 | 
0125 |     For Each item In mapItems
0126 |         valueToWrite = EvaluateExpression( _
0127 |             item("Expression"), _
0128 |             lo, _
0129 |             targetRow _
0130 |         )
0131 |         wsTpl.Range(item("TargetCell")).Value = valueToWrite
0132 |     Next item
0133 | 
0134 |     Application.ScreenUpdating = True
0135 |     
0136 |     
0137 | ' --- ЖУРНАЛ ДЕЙСТВИЙ ---
0138 |     Dim tplOrderNum As String
0139 |     Dim tplCol      As Long
0140 |     tplCol = GetOrderNumColumnIndex(lo)
0141 |     If tplCol > 0 Then
0142 |         tplOrderNum = wsData.Cells(targetRow, lo.Range.Column + tplCol - 1).Value
0143 |     End If
0144 |     WriteActionHistory wsData, targetRow, ACTION_TEMPLATE, tplOrderNum, "", "", templateSheetName
0145 | 
0146 |     wsTpl.Activate
0147 |     wsTpl.Range("A1").Select
0148 | 
0149 |     MsgBox "Данные перенесены в «" & templateSheetName & "»", vbInformation
0150 | 
0151 | End Sub
