0264 | ' ================================================================
0265 | ' ПЕРЕИМЕНОВАНИЕ ЧЕКБОКСОВ ПОСЛЕ УДАЛЕНИЯ СТРОКИ
0266 | ' Все cbWarr_N с N > deletedRow переименовываются в cbWarr_(N-1).
0267 | ' Порядок обхода — от меньших строк к большим (сортировка ASC),
0268 | ' чтобы не возникало конфликта имён.
0269 | ' ================================================================
0270 | Private Sub RenumberCheckboxesAfterDelete( _
0271 |     ByVal wsRep As Worksheet, _
0272 |     ByVal deletedRow As Long _
0273 | )
0274 |     Dim cb       As CheckBox
0275 |     Dim cbRows() As Long
0276 |     Dim n        As Long
0277 | 
0278 |     For Each cb In wsRep.CheckBoxes
0279 |         If Left(cb.Name, 7) = "cbWarr_" Then
0280 |             Dim r As Long
0281 |             r = CLng(Mid(cb.Name, 8))
0282 |             If r > deletedRow Then
0283 |                 ReDim Preserve cbRows(n)
0284 |                 cbRows(n) = r
0285 |                 n = n + 1
0286 |             End If
0287 |         End If
0288 |     Next cb
0289 | 
0290 |     If n = 0 Then Exit Sub
0291 | 
0292 |     ' Сортировка по ВОЗРАСТАНИЮ
0293 |     Dim i As Long, j As Long, tmp As Long
0294 |     For i = 0 To n - 2
0295 |         For j = 0 To n - i - 2
0296 |             If cbRows(j) > cbRows(j + 1) Then
0297 |                 tmp = cbRows(j): cbRows(j) = cbRows(j + 1): cbRows(j + 1) = tmp
0298 |             End If
0299 |         Next j
0300 |     Next i
0301 | 
0302 |     For i = 0 To n - 1
0303 |         On Error Resume Next
0304 |         wsRep.CheckBoxes("cbWarr_" & cbRows(i)).Name = "cbWarr_" & (cbRows(i) - 1)
0305 |         On Error GoTo 0
0306 |     Next i
0307 | End Sub
