1086 | ' --- Сортировка словаря по убыванию, возврат массивов ---
1087 | Private Sub SortDict(dict As Object, ByRef keys() As Variant, ByRef vals() As Long)
1088 |     Dim n As Long
1089 |     n = dict.Count - 1
1090 |     ReDim keys(n):  ReDim vals(n)
1091 |     Dim i As Long, k As Variant
1092 |     i = 0
1093 |     For Each k In dict.keys
1094 |         keys(i) = k: vals(i) = dict(k): i = i + 1
1095 |     Next k
1096 |     Dim j As Long, tK As Variant, tV As Long
1097 |     For i = 0 To n - 1
1098 |         For j = 0 To n - i - 1
1099 |             If vals(j) < vals(j + 1) Then
1100 |                 tV = vals(j): vals(j) = vals(j + 1): vals(j + 1) = tV
1101 |                 tK = keys(j): keys(j) = keys(j + 1): keys(j + 1) = tK
1102 |             End If
1103 |         Next j
1104 |     Next i
1105 | End Sub
