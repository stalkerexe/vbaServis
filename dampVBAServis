=== COMPONENT: modOrderNumber ===
TYPE: Standard Module
--------------------------------------------------
0001 | Option Explicit
0002 | 
0003 | '================================================================
0004 | ' МОДУЛЬ: modOrderNumber
0005 | '
0006 | ' Назначение:
0007 | '   Генерация и управление уникальными номерами заказов.
0008 | '
0009 | ' Формат номера: GR-2026-0001 / PL-2026-0001
0010 | '   GR / PL  — префикс типа (Гарантийный / Платный)
0011 | '   2026     — год из даты приёма (или текущий, если дата пуста)
0012 | '   0001     — порядковый номер, сквозной внутри года и типа,
0013 | '              дополненный нулями до 4 знаков
0014 | '
0015 | ' Уникальность обеспечивается сканом ОБЕИХ таблиц:
0016 | '   GR-2026-0001 невозможен в Платном, если уже есть в Гарантийном,
0017 | '   потому что префиксы разные. Но счётчик для GR ищется только
0018 | '   среди GR-записей, для PL — только среди PL-записей.
0019 | '================================================================
0020 | 
0021 | 
0022 | '================================================================
0023 | ' ГЛАВНАЯ ФУНКЦИЯ — сгенерировать следующий номер заказа
0024 | '================================================================
0025 | ' Аргументы:
0026 | '   sheetName — имя листа (DATA_SHEET или DATA_SHEET_PAID)
0027 | '   orderYear — год для номера (обычно год даты приёма)
0028 | '
0029 | ' Алгоритм:
0030 | '   1. Определяем префикс по листу (GR / PL)
0031 | '   2. Строим маску поиска: "GR-2026-####"
0032 | '   3. Сканируем столбец COL_ORDER_NUM в нужной таблице
0033 | '   4. Среди всех найденных номеров за этот год берём максимальный
0034 | '   5. Возвращаем максимальный + 1, отформатированный
0035 | '
0036 | ' Почему не используем Count строк как счётчик:
0037 | '   При удалении заказов строки убывают, и новый заказ мог бы
0038 | '   получить номер уже существующего. Скан максимума гарантирует
0039 | '   уникальность даже после многократных удалений.
0040 | '================================================================
0041 | Public Function GenerateOrderNumber( _
0042 |     ByVal sheetName As String, _
0043 |     ByVal orderYear As Long _
0044 | ) As String
0045 | 
0046 |     Dim prefix  As String
0047 |     Dim maxNum  As Long
0048 |     Dim ws      As Worksheet
0049 |     Dim lo      As ListObject
0050 |     Dim colNum  As Long
0051 |     Dim r       As ListRow
0052 |     Dim cellVal As String
0053 |     Dim parsed  As Long
0054 | 
0055 |     prefix = GetOrderPrefix(sheetName)
0056 |     maxNum = 0
0057 | 
0058 |     ' --- Сканируем таблицу текущего листа ---
0059 |     Set ws = ThisWorkbook.Sheets(sheetName)
0060 |     Set lo = ws.ListObjects(GetTableName(sheetName))
0061 | 
0062 |     If Not lo.DataBodyRange Is Nothing Then
0063 |         colNum = GetOrderNumColumnIndex(lo)
0064 | 
0065 |         If colNum > 0 Then
0066 |             For Each r In lo.ListRows
0067 |                 cellVal = Trim(r.Range.Cells(1, colNum).Value)
0068 |                 parsed = ParseOrderNumber(cellVal, prefix, orderYear)
0069 |                 If parsed > maxNum Then maxNum = parsed
0070 |             Next r
0071 |         End If
0072 |     End If
0073 | 
0074 |     ' --- Формируем следующий номер ---
0075 |     GenerateOrderNumber = prefix & "-" & orderYear & "-" & Format(maxNum + 1, "0000")
0076 | 
0077 | End Function
0078 | 
0079 | 
0080 | '================================================================
0081 | ' ЗАПИСАТЬ НОМЕР В НОВУЮ СТРОКУ
0082 | '================================================================
0083 | ' Вызывается из CommandButton2_Click (UserForm1) сразу после
0084 | ' lo.ListRows.Add, до записи остальных полей.
0085 | '
0086 | ' Аргументы:
0087 | '   ws        — лист данных
0088 | '   lo        — таблица
0089 | '   targetRow — номер строки листа (не индекс таблицы)
0090 | '   sheetName — имя листа (для определения префикса)
0091 | '   dateIn    — дата приёма из формы (строка "dd.mm.yyyy"),
0092 | '               используется для извлечения года номера
0093 | '================================================================
0094 | Public Sub WriteOrderNumber( _
0095 |     ByVal ws As Worksheet, _
0096 |     ByVal lo As ListObject, _
0097 |     ByVal targetRow As Long, _
0098 |     ByVal sheetName As String, _
0099 |     ByVal dateIn As String _
0100 | )
0101 |     Dim orderYear  As Long
0102 |     Dim orderNum   As String
0103 |     Dim colNum     As Long
0104 | 
0105 |     ' Год берём из даты приёма; если дата пустая — текущий год.
0106 |     ' Это важно: заказ, принятый в декабре 2025, должен иметь
0107 |     ' номер 2025-####, даже если вносится в систему в январе 2026.
0108 |     If Trim(dateIn) <> "" And IsDate(dateIn) Then
0109 |         orderYear = Year(CDate(dateIn))
0110 |     Else
0111 |         orderYear = Year(Date)
0112 |     End If
0113 | 
0114 |     orderNum = GenerateOrderNumber(sheetName, orderYear)
0115 | 
0116 |     colNum = GetOrderNumColumnIndex(lo)
0117 |     If colNum > 0 Then
0118 |         ws.Cells(targetRow, lo.Range.Column + colNum - 1).Value = orderNum
0119 |     End If
0120 | 
0121 | End Sub
0122 | 
0123 | 
0124 | '================================================================
0125 | ' ВСПОМОГАТЕЛЬНЫЕ
0126 | '================================================================
0127 | 
0128 | ' Префикс по имени листа
0129 | Private Function GetOrderPrefix(ByVal sheetName As String) As String
0130 |     If sheetName = DATA_SHEET_PAID Then
0131 |         GetOrderPrefix = ORDER_PREFIX_PAID
0132 |     Else
0133 |         GetOrderPrefix = ORDER_PREFIX_FREE
0134 |     End If
0135 | End Function
0136 | 
0137 | 
0138 | ' Найти индекс столбца номера заказа в таблице (1-based внутри таблицы)
0139 | ' Возвращает 0 если столбец не найден — защита от работы без столбца
0140 | Public Function GetOrderNumColumnIndex(ByVal lo As ListObject) As Long
0141 |     Dim col As ListColumn
0142 |     For Each col In lo.ListColumns
0143 |         If col.Name = "Номер заказа" Then
0144 |             GetOrderNumColumnIndex = col.Index
0145 |             Exit Function
0146 |         End If
0147 |     Next col
0148 |     GetOrderNumColumnIndex = 0
0149 | End Function
0150 | 
0151 | 
0152 | ' Разобрать номер вида "GR-2026-0042" и вернуть числовую часть (42).
0153 | ' Возвращает 0 если формат не совпадает с ожидаемым prefix+year.
0154 | ' Это защищает от случайного учёта номеров другого префикса или года.
0155 | Private Function ParseOrderNumber( _
0156 |     ByVal cellVal As String, _
0157 |     ByVal prefix As String, _
0158 |     ByVal orderYear As Long _
0159 | ) As Long
0160 | 
0161 |     ParseOrderNumber = 0
0162 | 
0163 |     ' Ожидаем ровно: "GR-2026-0042" = 12 символов при 4-значном номере
0164 |     ' Проверяем маску через Left/Mid, не RegEx — для совместимости
0165 |     Dim expectedHead As String
0166 |     expectedHead = prefix & "-" & orderYear & "-"
0167 | 
0168 |     ' Длина головы: len("GR-2026-") = 8
0169 |     If Len(cellVal) <= Len(expectedHead) Then Exit Function
0170 |     If Left(cellVal, Len(expectedHead)) <> expectedHead Then Exit Function
0171 | 
0172 |     Dim numPart As String
0173 |     numPart = Mid(cellVal, Len(expectedHead) + 1)
0174 | 
0175 |     ' Числовая часть должна состоять только из цифр
0176 |     Dim i As Long
0177 |     For i = 1 To Len(numPart)
0178 |         If Not Mid(numPart, i, 1) Like "[0-9]" Then Exit Function
0179 |     Next i
0180 | 
0181 |     On Error Resume Next
0182 |     ParseOrderNumber = CLng(numPart)
0183 |     On Error GoTo 0
0184 | 
0185 | End Function
0186 | 


