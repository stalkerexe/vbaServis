0003 | Public Function GetValidatedRow( _
0004 |     ByVal ws As Worksheet, _
0005 |     ByVal lo As ListObject, _
0006 |     Optional ByVal needData As Boolean = True, _
0007 |     Optional ByVal sheetName As String = DATA_SHEET _
0008 | ) As Long
0009 | 
0010 |     Dim rowNum As Long
0011 | 
0012 |     '---------------------------------
0013 |     ' 0. таблица пуста
0014 |     '---------------------------------
0015 |     If lo Is Nothing Then
0016 |         MsgBox "Таблица не найдена.", vbCritical
0017 |         Exit Function
0018 |     End If
0019 | 
0020 |     If lo.DataBodyRange Is Nothing Then
0021 |         MsgBox "В таблице нет ни одной записи.", vbExclamation
0022 |         Exit Function
0023 |     End If
0024 | 
0025 |     '---------------------------------
0026 |     ' 1. активная ячейка
0027 |     '---------------------------------
0028 |     If Not Selection Is Nothing Then
0029 |         If Selection.CountLarge = 1 Then
0030 |             If Selection.Parent.Name = ws.Name Then
0031 |                 If Not Intersect(Selection, lo.DataBodyRange) Is Nothing Then
0032 |                     rowNum = Selection.Row
0033 |                 End If
0034 |             End If
0035 |         End If
0036 |     End If
0037 | 
0038 |     '---------------------------------
0039 |     ' 2. fallback — Helper
0040 |     '    A2 — гарантийный
0041 |     '    B2 — платный
0042 |     '---------------------------------
0043 |     If rowNum = 0 Then
0044 |         If sheetName = DATA_SHEET_PAID Then
0045 |             rowNum = Val(ThisWorkbook.Sheets(HELPER_SHEET).Range("B2").Value)
0046 |         Else
0047 |             rowNum = Val(ThisWorkbook.Sheets(HELPER_SHEET).Range("A2").Value)
0048 |         End If
0049 |     End If
0050 | 
0051 |     '---------------------------------
0052 |     ' 3. вообще ничего не выбрано
0053 |     '---------------------------------
0054 |     If rowNum = 0 Then
0055 |         MsgBox "Выберите строку таблицы.", vbExclamation
0056 |         Exit Function
0057 |     End If
0058 | 
0059 |     '---------------------------------
0060 |     ' 4. строка вне таблицы
0061 |     '---------------------------------
0062 |     If Intersect(ws.Rows(rowNum), lo.DataBodyRange) Is Nothing Then
0063 |         MsgBox "Выбранная строка не относится к таблице.", vbCritical
0064 |         Exit Function
0065 |     End If
0066 | 
0067 |     '---------------------------------
0068 |     ' 5. проверка данных
0069 |     '---------------------------------
0070 |     If needData Then
0071 |         If Trim(ws.Cells(rowNum, COL_NAME).Value) = "" Then
0072 |             MsgBox "В выбранной строке нет данных.", vbExclamation
0073 |             Exit Function
0074 |         End If
0075 |     End If
0076 | 
0077 |     '---------------------------------
0078 |     ' OK
0079 |     '---------------------------------
0080 |     GetValidatedRow = rowNum
0081 | 
0082 | End Function
