0048 |     Dim forgotThreshold As Double
0049 |     forgotThreshold = CDbl(Date - FORGOTTEN_DAYS)
0050 | 
0051 |     On Error GoTo SafeExit
0052 | 
0053 |     ' ============================================================
0054 |     ' ГАРАНТИЙНЫЙ
0055 |     ' ============================================================
0056 |     Set loF = ThisWorkbook.Sheets(DATA_SHEET).ListObjects(TABLE_FREE)
0057 | 
