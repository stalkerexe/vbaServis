0202 | Private Function URLEncode(ByVal txt As String) As String
0203 |     Dim i As Integer, ch As String, result As String, code As Integer
0204 |     result = ""
0205 |     For i = 1 To Len(txt)
0206 |         ch = Mid(txt, i, 1)
0207 |         code = Asc(ch)
0208 |         Select Case code
0209 |             Case 65 To 90, 97 To 122, 48 To 57
0210 |                 result = result & ch
0211 |             Case Else
0212 |                 result = result & EncodeCharUTF8(ch)
0213 |         End Select
0214 |     Next i
0215 |     URLEncode = result
0216 | End Function
