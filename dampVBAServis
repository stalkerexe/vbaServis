0003 | '========================================
0004 | ' МОДУЛЬ: modBackup
0005 | ' Резервное копирование книги
0006 | '========================================
0007 | 
0008 | Private Const BACKUP_FOLDER   As String = "Backups"
0009 | Private Const MAX_BACKUPS     As Long = 10
0010 | Private Const TIMESTAMP_SEP   As String = "|"
0011 | 
0012 | 
0013 | ' ================================================================
0014 | ' ГЛАВНАЯ ПРОЦЕДУРА — создать резервную копию
0015 | ' ================================================================
0016 | ' УЛУЧШЕНИЕ: вынесены Magic Strings в константы.
0017 | ' Добавлена проверка: если файл с таким именем уже существует
0018 | ' (создан в ту же минуту), копирование пропускается с сообщением,
0019 | ' а не перезаписывает предыдущий бэкап молча.
0020 | ' ================================================================
0021 | Public Sub СоздатьРезервнуюКопию()
0022 | 
0023 |     Dim backupPath As String
0024 |     Dim backupName As String
0025 |     Dim fullPath   As String
0026 | 
0027 |     backupPath = ThisWorkbook.Path & "\" & BACKUP_FOLDER & "\"
0028 |     backupName = "РезервнаяКопия_" & Format(Now, "dd.mm.yyyy_hhmm") & ".xlsm"
0029 |     fullPath = backupPath & backupName
0030 | 
0031 |     ' Создаём папку если не существует
0032 |     If Dir(backupPath, vbDirectory) = "" Then
0033 |         On Error Resume Next
0034 |         MkDir backupPath
0035 |         On Error GoTo 0
0036 |         ' Проверяем что папка реально создалась
0037 |         If Dir(backupPath, vbDirectory) = "" Then
0038 |             MsgBox "Не удалось создать папку резервных копий:" & vbCrLf & _
0039 |                    backupPath, vbCritical, "Резервное копирование"
0040 |             Exit Sub
0041 |         End If
0042 |     End If
0043 | 
0044 |     ' Защита от двойного запуска в одну минуту
0045 |     If Dir(fullPath) <> "" Then
0046 |         MsgBox "Резервная копия за эту минуту уже существует:" & vbCrLf & _
0047 |                fullPath, vbExclamation, "Резервное копирование"
0048 |         Exit Sub
0049 |     End If
0050 | 
0051 |     ' Очищаем старые копии ПЕРЕД сохранением новой,
0052 |     ' чтобы после очистки в папке было ровно MAX_BACKUPS - 1 файл,
0053 |     ' и новый файл стал ровно MAX_BACKUPS-м.
0054 |     ОчиститьСтарыеКопии backupPath, MAX_BACKUPS - 1
0055 | 
0056 |     ' Сохраняем копию
0057 |     On Error GoTo ErrSave
0058 |     ThisWorkbook.SaveCopyAs fullPath
0059 |     On Error GoTo 0
0060 | 
0061 |     MsgBox "Резервная копия создана:" & vbCrLf & fullPath, _
0062 |            vbInformation, "Резервное копирование"
0063 |     Exit Sub
0064 | 
0065 | ErrSave:
0066 |     MsgBox "Ошибка при создании резервной копии:" & vbCrLf & _
0067 |            Err.Description, vbCritical, "Резервное копирование"
0068 | 
0069 | End Sub
0070 | 
0071 | 
0072 | ' ================================================================
0073 | ' ОЧИСТКА СТАРЫХ КОПИЙ — оставить не более maxFiles файлов
0074 | ' ================================================================
0075 | ' ИСПРАВЛЕНИЕ #1 (главное): старый код хранил дату как строку
0076 | '   fileArray(i) = file.Path & "|" & file.DateCreated
0077 | ' и затем восстанавливал её через CDate(). Это зависит от
0078 | ' региональных настроек Windows. На машинах с форматом даты
0079 | ' отличным от системного CDate() падал с ошибкой несоответствия
0080 | ' типов, или конвертировал неправильно — и удалял не те файлы.
0081 | '
0082 | ' ИСПРАВЛЕНИЕ #2: теперь дата хранится как CDbl() —
0083 | ' числовое представление Date в VBA (количество дней от
0084 | ' 30.12.1899). Числа сортируются строго, локаль не влияет.
0085 | ' Формат записи: "0000000000.000|C:\path\to\file.xlsm"
0086 | ' Число выравнивается нулями слева > строковая сортировка
0087 | ' даёт тот же результат, что числовая. Разделитель TIMESTAMP_SEP
0088 | ' стоит ПОСЛЕ числа, чтобы не мешать лексикографической
0089 | ' сортировке.
0090 | '
0091 | ' ИСПРАВЛЕНИЕ #3: старый код объявлял Dim fileArray() внутри
0092 | ' If-блока — это нарушение правил VBA (Dim должен быть в начале
0093 | ' процедуры или вне условных блоков при Option Explicit).
0094 | ' Перенесено в начало процедуры.
0095 | '
0096 | ' ИСПРАВЛЕНИЕ #4: старый код проверял files.Count > maxFiles,
0097 | ' но files — это живая коллекция FSO, а не снимок. После
0098 | ' удаления файла Count менялся и цикл мог пропустить файлы.
0099 | ' Теперь все пути собираются в массив сразу, до удаления.
0100 | ' ================================================================
0101 | Private Sub ОчиститьСтарыеКопии( _
0102 |     ByVal backupPath As String, _
0103 |     ByVal maxFiles As Long _
0104 | )
0105 |     Dim fso        As Object
0106 |     Dim folder     As Object
0107 |     Dim file       As Object
0108 |     Dim fileCount  As Long
0109 |     Dim i          As Long
0110 | 
0111 |     ' Массив объявлен заранее (фикс #3)
0112 |     Dim fileArray() As String
0113 | 
0114 |     Set fso = CreateObject("Scripting.FileSystemObject")
0115 | 
0116 |     If Not fso.FolderExists(backupPath) Then Exit Sub
0117 | 
0118 |     Set folder = fso.GetFolder(backupPath)
0119 |     fileCount = folder.files.Count
0120 | 
0121 |     ' Нечего чистить
0122 |     If fileCount <= maxFiles Then Exit Sub
0123 | 
0124 |     ' Собираем снимок файлов ДО удаления (фикс #4)
0125 |     ' Формат: "NNNNNNNNNNNN.NNN|полный\путь\к\файлу"
0126 |     ' Число = CDbl(DateCreated), выровнено нулями до 16 символов
0127 |     ReDim fileArray(1 To fileCount)
0128 |     i = 1
0129 |     For Each file In folder.files
0130 |         ' Format с маской "000000000000.000" гарантирует, что
0131 |         ' строковая сортировка (по алфавиту) совпадает с
0132 |         ' числовой сортировкой дат (фикс #1 и #2)
0133 |         fileArray(i) = Format(CDbl(file.DateCreated), "000000000000.000") & _
0134 |                        TIMESTAMP_SEP & file.Path
0135 |         i = i + 1
0136 |     Next file
0137 | 
0138 |     ' Сортируем от старых к новым — обычный BubbleSort,
0139 |     ' но теперь сравниваем строки, а не CDate() (фикс #1)
0140 |     СортироватьМассивСтрок fileArray
0141 | 
0142 |     ' Удаляем самые старые (они в начале массива после сортировки)
0143 |     Dim toDelete As Long
0144 |     toDelete = fileCount - maxFiles
0145 | 
0146 |     For i = 1 To toDelete
0147 |         Dim filePath As String
0148 |         filePath = Split(fileArray(i), TIMESTAMP_SEP)(1)
0149 |         On Error Resume Next
0150 |         fso.DeleteFile filePath
0151 |         On Error GoTo 0
0152 |     Next i
0153 | 
0154 | End Sub
0155 | 
0156 | 
0157 | ' ================================================================
0158 | ' СОРТИРОВКА МАССИВА СТРОК (от меньшего к большему)
0159 | ' ================================================================
0160 | ' ПЕРЕИМЕНОВАНО: СортироватьФайлыПоДате > СортироватьМассивСтрок
0161 | '
0162 | ' Причина: функция теперь универсальная — сортирует любые строки,
0163 | ' не знает ничего про даты или файлы. Всё знание о формате
0164 | ' (число + разделитель + путь) сосредоточено в вызывающей
0165 | ' процедуре ОчиститьСтарыеКопии.
0166 | '
0167 | ' УБРАНО: CDate(Split(...)(1)) — было источником бага с локалью.
0168 | ' Теперь сравниваются строки напрямую: так как числовая часть
0169 | ' выровнена нулями, лексикографический порядок = хронологический.
0170 | ' ================================================================
0171 | Private Sub СортироватьМассивСтрок(ByRef arr() As String)
0172 | 
0173 |     Dim i    As Long
0174 |     Dim j    As Long
0175 |     Dim temp As String
0176 | 
0177 |     For i = LBound(arr) To UBound(arr) - 1
0178 |         For j = i + 1 To UBound(arr)
0179 |             ' Строковое сравнение работает корректно,
0180 |             ' потому что числа выровнены нулями слева
0181 |             If arr(i) > arr(j) Then
0182 |                 temp = arr(i)
0183 |                 arr(i) = arr(j)
0184 |                 arr(j) = temp
0185 |             End If
0186 |         Next j
0187 |     Next i
0188 | 
0189 | End Sub
0190 | 
0191 | ' ================================================================
0192 | ' ТИХИЙ АВТО-БЭКАП — без алертов об успехе и дублях
0193 | ' Вызывается автоматически при закрытии книги.
0194 | ' Единственный алерт — если папку невозможно создать
0195 | ' (нет прав на диск), т.к. это требует действий от пользователя.
0196 | ' ================================================================
0197 | Public Sub СоздатьРезервнуюКопиюТихо()
0198 | 
0199 |     Dim backupPath As String
0200 |     Dim backupName As String
0201 |     Dim fullPath   As String
0202 | 
0203 |     backupPath = ThisWorkbook.Path & "\" & BACKUP_FOLDER & "\"
0204 |     If Weekday(Date, vbMonday) <> 5 Then Exit Sub
0205 |     backupName = "РезервнаяКопия_" & Format(Now, "dd.mm.yyyy_hhmm") & ".xlsm"
0206 |     fullPath = backupPath & backupName
0207 | 
0208 |     ' Создаём папку если не существует
0209 |     If Dir(backupPath, vbDirectory) = "" Then
0210 |         On Error Resume Next
0211 |         MkDir backupPath
0212 |         On Error GoTo 0
0213 |         ' Папку создать не удалось — это требует внимания пользователя
0214 |         If Dir(backupPath, vbDirectory) = "" Then
0215 |             MsgBox "Авто-бэкап: не удалось создать папку:" & vbCrLf & _
0216 |                    backupPath, vbCritical, "Резервное копирование"
0217 |             Exit Sub
0218 |         End If
0219 |     End If
0220 | 
0221 |     ' Копия за эту минуту уже есть — тихо пропускаем
0222 |     If Dir(fullPath) <> "" Then Exit Sub
0223 | 
0224 |     ' Чистим старые копии
0225 |     ОчиститьСтарыеКопии backupPath, MAX_BACKUPS - 1
0226 | 
0227 |     ' Сохраняем — ошибку тоже глотаем тихо
0228 |     ' (закрытие книги не должно блокироваться из-за бэкапа)
0229 |     On Error Resume Next
0230 |     ThisWorkbook.SaveCopyAs fullPath
0231 |     On Error GoTo 0
0232 | 
0233 | End Sub


