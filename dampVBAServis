0459 |     Dim cleanTxt As String
0460 |     Dim parts()  As String
0461 |     Dim dd As Long, mm As Long, yy As Long
0462 | 
0463 |     txt = Trim(txt)
0464 |     If txt = "" Then IsValidDateInput = True: Exit Function
